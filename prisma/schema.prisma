// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         String   @default("USER") // ADMIN or USER
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  companies    Company[]
  campaigns    Campaign[]
  emails       Email[]
}

model Company {
  id           String   @id @default(cuid())
  name         String
  type         String   @default("SHIPPOWNER") // SHIPOWNER, ARMADOR, BROKER, AGENT
  email        String?
  phone        String?
  country      String?
  city         String?
  website      String?
  status       String   @default("NEW") // NEW, QUALIFIED, CONTACTED, RESPONDED, CLOSED
  score        Int      @default(0)
  notes        String?
  lastContact  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])
  vessels      Vessel[]
  emails       Email[]
}

model Vessel {
  id           String   @id @default(cuid())
  name         String
  imo          String?  @unique
  type         String?
  flag         String?
  status       String   @default("OTHER") // IN_ANGOLA, EN_ROUTE, OTHER
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Campaign {
  id           String   @id @default(cuid())
  name         String
  description  String?
  status       String   @default("DRAFT") // DRAFT, ACTIVE, PAUSED, COMPLETED
  serviceType  String?  // DIVING, SHIPCHANDLER, WASTE, BUNKER
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])
  emails       Email[]
}

model Email {
  id           String   @id @default(cuid())
  subject      String
  body         String
  status       String   @default("QUEUED") // QUEUED, SENT, OPENED, CLICKED, REPLIED, FAILED
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  repliedAt    DateTime?
  failedReason String?
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id])
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Report {
  id           String   @id @default(cuid())
  type         String   // LEADS, EMAILS, CAMPAIGNS, PERFORMANCE
  title        String?
  data         String   // JSON string
  generatedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
}

model Setting {
  id           String   @id @default(cuid())
  key         String   @unique
  value       String
  description  String?
  updatedAt    DateTime @updatedAt
}

model Notification {
  id           String   @id @default(cuid())
  type         String   // INFO, WARNING, SUCCESS, ERROR
  title        String
  message      String
  isRead       Boolean  @default(false)
  link         String?
  createdAt    DateTime @default(now())
}
